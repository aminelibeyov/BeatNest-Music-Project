{
  "name": "beatnest-server",
  "version": "1.0.0",
  "description": "BeatNest Music Streaming Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "cross-env NODE_ENV=production npm run start",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "jest --runInBand",
    "seed": "node src/seed.js"
  },
  "keywords": [
    "beatnest",
    "music",
    "streaming",
    "spotify-clone"
  ],
  "author": "BeatNest Team",
  "license": "ISC",
  "engines": {
    "node": ">=16.x",
    "npm": ">=8.x"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.35.0",
    "express-validator": "^7.0.0",
    "joi": "^17.9.2",
    "express-async-handler": "^1.2.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "cross-env": "^7.0.3",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "eslint": "^8.40.0",
    "prettier": "^2.8.8",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "@types/jest": "^29.5.2"
  }
}
